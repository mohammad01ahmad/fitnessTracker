# OpenRouter — required, used for LLM nutrition extraction
OPENROUTER_API_KEY=

# Supabase — required. Service role key bypasses RLS for backend writes,
# never give it a NEXT_PUBLIC_ prefix.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_USER_ID=

# Unused by the wired code path (src/claude/gemini_client.ts is dead code,
# not imported anywhere) — kept here only because it's already in use locally.
GEMINI_API_KEY=

# Optional. Controls src/utils/logger.js (pino) — also used as Baileys' own
# logger, so this dials both down/up. One of: trace, debug, info, warn,
# error, fatal, silent. Defaults to "info" if unset.
LOG_LEVEL=

# No env var for WhatsApp auth: session lives in ./auth_session (gitignored).
# On a fresh server this directory won't exist — first boot prints a QR code
# to stdout; scan it once, and make sure ./auth_session persists across
# restarts/redeploys (it won't survive an ephemeral filesystem).
